          "request": {
            "method": "POST", "url": "{{baseUrl}}/contact",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"subject\": \"Inquiry about bulk orders\",\n  \"message\": \"Hi, I am interested in placing bulk orders for vegetables. Please get in touch.\"\n}" }
