          "name": "Reject Farmer",
          "request": { "method": "PATCH", "url": "{{baseUrl}}/admin/farmers/1/reject", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        },
        {
          "name": "All Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/products", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        },
        {
          "name": "All Orders",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/orders", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/admin/orders/1/status",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"orderStatus\": \"DELIVERED\"\n}" }
          }
        },
        {
          "name": "Add Category",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "formdata", "formdata": [
              {"key":"category","value":"{\"categoryName\":\"Roots & Tubers\",\"emoji\":\"🥕\",\"color\":\"#FF8C00\"}","type":"text","contentType":"application/json"}
            ]}
          }
        },
        {
          "name": "Contact Messages",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/contact-messages", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        },
        {
          "name": "Update Market Price",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/market-prices/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"commodityName\": \"Tomato\",\n  \"emoji\": \"🍅\",\n  \"price\": 52.00,\n  \"change\": 7.0,\n  \"unit\": \"per kg\"\n}" }
          }
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "item": [
