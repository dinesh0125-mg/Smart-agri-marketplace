# ============================================
# SMART AGRICULTURE MARKETPLACE - ENVIRONMENT
# Copy this file to .env and fill in your values
# ============================================

# ---- DATABASE ----
DB_URL=jdbc:mysql://localhost:3306/smart_agri_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_db_password

# ---- JWT ----
JWT_SECRET=your_jwt_secret_hex_key_at_least_64_chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ---- CLOUDINARY ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- RAZORPAY ----
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---- EMAIL (Gmail SMTP) ----
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com

# ---- GOOGLE OAUTH ----
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ---- APP URLs ----
APP_BASE_URL=http://localhost:8080/api
APP_FRONTEND_URL=http://localhost:5173
